COMPOSE_PROJECT_NAME=ghostfolio

# CACHE
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<INSERT_REDIS_PASSWORD>

# POSTGRES
POSTGRES_DB=ghostfolio-db
POSTGRES_USER=user
POSTGRES_PASSWORD=<INSERT_POSTGRES_PASSWORD>

# VARIOUS
ACCESS_TOKEN_SALT=<INSERT_RANDOM_STRING>
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?connect_timeout=300
JWT_SECRET_KEY=<INSERT_RANDOM_STRING>

# GHOSTFOLIO SETTINGS
BASE_CURRENCY=CNY

# CHRYSANTHA SYNC
# Get your access token: Ghostfolio → Settings → Access Token → Create
GHOSTFOLIO_ACCESS_TOKEN=<INSERT_YOUR_GHOSTFOLIO_ACCESS_TOKEN>
# A-share symbols are configured in Ghostfolio UI (create MANUAL symbols: SH600519, SZ002594, etc.)
# The sync script auto-discovers A-share symbols from your Ghostfolio market data.

# ── TRADING BRIDGE (Chrysantha ↔ TradingAgents) ─────────
# LLM provider: openai / anthropic / google / deepseek / openrouter
LLM_PROVIDER=openai
DEEP_THINK_MODEL=deepseek-v4-pro
QUICK_THINK_MODEL=deepseek-v4-flash
OPENAI_API_KEY=
# Optional: custom API base URL
BACKEND_URL=https://api.deepseek.com
# Trading bridge service URL (internal Docker network)
TRADING_BRIDGE_URL=http://trading-bridge:8000
# Path to TradingAgents-CN on host (for Docker volume mount)
TRADINGAGENTS_HOST_PATH=/mnt/d/Project/TradingAgents-CN

# ── EXECUTOR BRIDGE (Chrysantha ↔ vnpy) ─────────────────
EXECUTOR_BRIDGE_URL=http://executor-bridge:8001
# vnpy Web Trader credentials
VNPY_BASE_URL=http://vnpy:8000
VNPY_USERNAME=admin
VNPY_PASSWORD=<INSERT_VNPY_PASSWORD>
# Auto-execute defaults
AUTO_EXECUTE_CONFIDENCE_THRESHOLD=0.7
AUTO_EXECUTE_MAX_POSITION_PCT=0.1
