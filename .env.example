COMPOSE_PROJECT_NAME=ghostfolio

# CACHE
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<INSERT_REDIS_PASSWORD>

# POSTGRES
POSTGRES_DB=ghostfolio-db
POSTGRES_USER=user
POSTGRES_PASSWORD=<INSERT_POSTGRES_PASSWORD>

# VARIOUS
ACCESS_TOKEN_SALT=<INSERT_RANDOM_STRING>
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?connect_timeout=300
JWT_SECRET_KEY=<INSERT_RANDOM_STRING>

# GHOSTFOLIO SETTINGS
BASE_CURRENCY=CNY

# CHRYSANTHA SYNC
# Get your access token: Ghostfolio → Settings → Access Token → Create
GHOSTFOLIO_ACCESS_TOKEN=<INSERT_YOUR_GHOSTFOLIO_ACCESS_TOKEN>
# A-share symbols are configured in Ghostfolio UI (create MANUAL symbols: SH600519, SZ002594, etc.)
# The sync script auto-discovers A-share symbols from your Ghostfolio market data.
